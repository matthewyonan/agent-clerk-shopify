{
  "name": "agent-clerk-shopify",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "prisma generate && remix vite:build",
    "start": "npx prisma migrate deploy && remix-serve ./build/server/index.js",
    "dev": "shopify app dev",
    "lint": "eslint --cache --cache-location ./node_modules/.cache/eslint .",
    "shopify": "shopify",
    "typecheck": "tsc",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "docker-start": "npm run setup && remix vite:build && remix-serve ./build/server/index.js",
    "setup": "prisma generate && prisma migrate deploy"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^5.22.0",
    "@remix-run/node": "^2.15.0",
    "@remix-run/react": "^2.15.0",
    "@remix-run/serve": "^2.15.0",
    "@shopify/app-bridge-react": "^4.1.0",
    "@shopify/polaris": "^13.9.0",
    "@shopify/shopify-api": "^11.7.0",
    "@shopify/shopify-app-remix": "^3.4.0",
    "@shopify/shopify-app-session-storage-prisma": "^5.2.0",
    "isbot": "^5.1.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "uuid": "^11.0.0"
  },
  "devDependencies": {
    "@remix-run/dev": "^2.15.0",
    "@shopify/api-codegen-preset": "^1.1.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@types/uuid": "^10.0.0",
    "prisma": "^5.22.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vite-tsconfig-paths": "^5.1.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
